
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Rules for the 'wallets' collection
    match /wallets/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Rules for transactions subcollection
      match /transactions/{transactionId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Rules for the 'sellers' collection
    match /sellers/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    // Rules for the 'reports' collection
    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Rules for comments subcollection
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // Rules for the 'alerts' collection
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if false; // Only system/admin can create alerts
    }
    
    // Rules for other collections
    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    
    match /areas/{areaId} {
        allow read: if true;
        allow write: if false; // Managed by backend
    }

    match /transactions/{transactionId} {
        allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for the 'pending_products' collection
    match /pending_products/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Rules for the 'approved_products' collection
    match /approved_products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Rules for the 'events' collection
    match /events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Rules for the 'businesses' collection
    match /businesses/{businessId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
